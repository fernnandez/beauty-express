# Server
PORT=3000
NODE_ENV=development

# CORS (URL do frontend, separadas por vírgula se houver mais de uma)
CORS_ORIGIN=http://localhost:5173

# PostgreSQL
# Railway/produção: use a URL interna do serviço Postgres
# DATABASE_URL=${{Postgres.DATABASE_URL}}
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=beauty_express
DB_SYNCHRONIZE=true
DB_LOGGING=false
# DB_SSL=true
# Em produção: DB_SYNCHRONIZE=false e rode migrations antes do start
# DB_MIGRATIONS_RUN=true  # opcional: aplica migrations ao subir a API

# JWT
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Rate limit nos logins (por IP)
THROTTLE_LOGIN_LIMIT=10
THROTTLE_LOGIN_TTL_MS=60000
