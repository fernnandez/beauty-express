# URL da API Backend (apenas REST, sem frontend embutido)
VITE_API_URL=http://localhost:3000
# Apenas em localhost (dev): portal padrão antes de escolher no seletor.
# NÃO defina VITE_PORTAL_HOST na Vercel — em produção o host vem do domínio da URL.
# VITE_PORTAL_HOST=mariaborboleta.fernnandez.com
# VITE_PORTAL_HOST=barbearia.fernnandez.com
# Produção: sempre com https:// (ex.: https://sua-api.up.railway.app)
# Railway CORS_ORIGIN: liste cada domínio do frontend, ex.:
# CORS_ORIGIN=https://mariaborboleta.fernnandez.com,https://lucasoliveira.fernnandez.com
